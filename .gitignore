# -------------------------
# Deny everything by default
# -------------------------
*

# -------------------------
# Allow structure traversal
# -------------------------
!*/

# -------------------------
# Explicit allowlist (source of truth)
# -------------------------
!.gitignore
!README.md
!LICENSE
!.github/
!CMakeLists.txt

# concept demo
!concept_demo/
!concept_demo/build_occupancy_table.py
!concept_demo/build_state_space.py
!concept_demo/build_trajectory_transitions.py
!concept_demo/xml2duckdb.py

# external tools (installed locally, not versioned)
externals/**
!externals/
!externals/sumo_target/
!externals/sumo_target/.gitkeep

# submodules (external dependencies)
!submodules/
!submodules/**
!submodules/**/*

# src 
!src/
!src/CMakeLists.txt

# docs (source files only)
!docs/
!docs/sphinx/
!docs/sphinx/**
!docs/latex/
!docs/latex/**
!docs/figs/
!docs/figs/**
!docs/Doxyfile

# GitHub Actions
!.github/workflows/
!.github/workflows/**

# -------------------------
# Explicitly deny generated artifacts
# -------------------------
docs/build/
docs/_build/
docs/_site/
docs/doxygen/
