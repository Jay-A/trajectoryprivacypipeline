# -------------------------
# Deny everything by default
# -------------------------
*

# -------------------------
# Allow structure traversal
# -------------------------
!*/

# -------------------------
# Explicit allowlist (source of truth)
# -------------------------
!.gitignore
!README.md
!LICENSE
!.github/
!CMakeLists.txt

# src 
!src/
!src/CMakeLists.txt

# docs (source files only)
!docs/
!docs/sphinx/
!docs/sphinx/**
!docs/latex/
!docs/latex/**
!docs/figs/
!docs/figs/**
!docs/Doxyfile

# GitHub Actions
!.github/workflows/
!.github/workflows/**

# -------------------------
# Explicitly deny generated artifacts
# -------------------------
docs/build/
docs/_build/
docs/_site/
docs/doxygen/
