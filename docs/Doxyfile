#---------------------------------------------------------------------------
# Project metadata
#---------------------------------------------------------------------------
PROJECT_NAME           = "Trajectory Privacy Pipeline"
PROJECT_BRIEF          = "Modular framework for performance and privacy analysis of trajectory processing system"
PROJECT_NUMBER         = "1.0"

# IMPORTANT: keep generated outputs isolated for Sphinx/Breathe integration
OUTPUT_DIRECTORY       = ../docs/doxygen
CREATE_SUBDIRS         = YES

#---------------------------------------------------------------------------
# Input files
#---------------------------------------------------------------------------
INPUT                  = ../src ../bindings
FILE_PATTERNS          = *.h *.hpp *.cpp *.cc
RECURSIVE              = YES
EXCLUDE                =

#---------------------------------------------------------------------------
# Source extraction (full visibility for research / API graphing)
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
EXTRACT_ANON_NSPACES   = YES

#---------------------------------------------------------------------------
# Build settings
#---------------------------------------------------------------------------
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

# REQUIRED for Sphinx/Breathe
GENERATE_XML           = YES
XML_OUTPUT             = xml

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = ../cpp

#---------------------------------------------------------------------------
# Warnings & logging (CI-friendly)
#---------------------------------------------------------------------------
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

#---------------------------------------------------------------------------
# Cross-references / navigation
#---------------------------------------------------------------------------
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

USE_MDFILE_AS_MAINPAGE = ../README.md

#---------------------------------------------------------------------------
# Source browsing (useful for local debugging, ignored by Sphinx)
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
VERBATIM_HEADERS       = YES

#---------------------------------------------------------------------------
# Encoding
#---------------------------------------------------------------------------
INPUT_ENCODING         = UTF-8
